{
  "entities": {
    "Threat": {
      "title": "Threat",
      "description": "A detected security threat or alert.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique identifier for the threat." },
        "source": { "type": "string", "description": "The source of the threat (e.g., email address, IP)." },
        "type": { "type": "string", "description": "The specific type of threat." },
        "category": { "type": "string", "enum": ["Phishing", "Malware", "Spoofing", "Social", "Other"] },
        "risk": { "type": "string", "enum": ["Critical", "High", "Medium", "Low"] },
        "timestamp": { "type": "string", "description": "When the threat was detected." },
        "status": { "type": "string", "enum": ["active", "reviewed"] },
        "aiAnalysis": {
          "type": "object",
          "properties": {
            "summary": { "type": "string" },
            "detailedSummary": { "type": "string" },
            "confidence": { "type": "number" },
            "recommendation": { "type": "string" },
            "technicalDetails": { "type": "string" },
            "detectionMethod": { "type": "string" },
            "impactScore": { "type": "number" },
            "affectedAssets": { "type": "string" },
            "mitreTechnique": { "type": "string" },
            "mitreTactic": { "type": "string" }
          }
        },
        "createdBy": { "type": "string", "description": "UID of the user who created or manually scanned this threat." }
      },
      "required": ["id", "source", "type", "category", "risk", "timestamp", "status"]
    },
    "User": {
      "title": "User",
      "description": "A security analyst or user of the platform.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "analyst"] }
      },
      "required": ["uid", "email"]
    }
  },
  "firestore": {
    "/threats/{threatId}": {
      "schema": "Threat",
      "description": "Global feed of security threats."
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile information."
    }
  }
}
